{
  "name": "track-log-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser-based, fully client-side tool to parse aRacer ECU .loga logs: convert to RaceChrono .nmea and analyse laps & telemetry.",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "echarts-gl": "2.1.0",
    "fflate": "^0.8.3",
    "grid-layout-plus": "^1.1.1",
    "idb": "^8.0.3",
    "pinia": "^3.0.4",
    "sql.js": "^1.14.1",
    "uplot": "^1.6.32",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.1",
    "@types/node": "^26.1.1",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wrangler": "^4.107.0"
  }
}
