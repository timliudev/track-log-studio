{
  "name": "aracer-loga-analysis",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser-based, fully client-side tool to parse aRacer ECU .loga logs: convert to RaceChrono .nmea and analyse laps & telemetry.",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "idb": "^8.0.3",
    "pinia": "^3.0.4",
    "uplot": "^1.6.32",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
