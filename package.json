{
  "name": "track-log-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser-based, fully client-side tool to parse aRacer ECU .loga logs: convert to RaceChrono .nmea and analyse laps & telemetry.",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "icons:generate": "node scripts/generate-pwa-icons.mjs",
    "fixtures:make": "node scripts/make-fixtures.mjs",
    "bench:parse": "node scripts/perf/run-with-vite.mjs scripts/perf/bench-parse.ts",
    "bench:pipeline": "node scripts/perf/run-with-vite.mjs scripts/perf/bench-pipeline.ts"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "echarts-gl": "2.1.0",
    "fflate": "^0.8.3",
    "grid-layout-plus": "^1.1.1",
    "idb": "^8.0.3",
    "pinia": "^4.0.2",
    "sql.js": "^1.14.1",
    "uplot": "^1.6.32",
    "vue": "^3.5.40",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@types/node": "^26.1.1",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.11.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "sharp": "^0.35.3",
    "fast-uri": "^3.1.4"
  }
}
